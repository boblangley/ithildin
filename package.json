{
  "name": "@boblangley/ithildin",
  "version": "0.1.0",
  "description": "Static site generator for browsing git repositories",
  "type": "module",
  "bin": {
    "ithildin": "bin/ithildin.js"
  },
  "scripts": {
    "build:dist": "node ./scripts/build-dist.js",
    "test": "node ./scripts/smoke-test.js"
  },
  "keywords": [
    "static-site",
    "documentation",
    "code-browser",
    "generator"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boblangley/ithildin.git"
  },
  "ithildin": {
    "categories": [
      "tools"
    ],
    "tags": [
      "git",
      "source-code"
    ]
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "alpinejs": "^3.14.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "shiki": "^1.22.2"
  },
  "devDependencies": {}
}
